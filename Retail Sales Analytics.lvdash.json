{
  "datasets": [
    {
      "name": "375d686f",
      "displayName": "monthly_revenue",
      "queryLines": [
        "SELECT invoice_month, country, total_revenue,\r\n",
        "       num_invoices, unique_customers\r\n",
        "FROM   default.gold_monthly_revenue\r\n",
        "WHERE  country IN ('United Kingdom','Germany','France',\r\n",
        "                   'Netherlands','Australia')\r\n",
        "ORDER BY invoice_month"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "b55bd0e3",
      "displayName": "top_products",
      "queryLines": [
        "SELECT description, total_revenue, units_sold, num_orders\r\n",
        "FROM   default.gold_top_products\r\n",
        "ORDER BY total_revenue DESC\r\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "6f810160",
      "displayName": "customer_segments",
      "queryLines": [
        "SELECT segment,\r\n",
        "       COUNT(*) AS num_customers,\r\n",
        "       ROUND(AVG(monetary_value), 2) AS avg_spend,\r\n",
        "       ROUND(SUM(monetary_value), 2) AS total_spend\r\n",
        "FROM   default.gold_customer_rfm\r\n",
        "GROUP BY segment\r\n",
        "ORDER BY total_spend DESC"
      ]
    },
    {
      "name": "5b50e9b1",
      "displayName": "dow_sales",
      "queryLines": [
        "SELECT day_name, total_revenue, num_invoices\r\n",
        "FROM   default.gold_dow_sales\r\n",
        "ORDER BY day_of_week"
      ]
    }
  ],
